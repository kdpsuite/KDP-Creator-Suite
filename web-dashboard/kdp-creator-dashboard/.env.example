# ============================================================================
# KDP Creator Suite Frontend - Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the actual values.
# NEVER commit the .env.local file to version control.
# ============================================================================

# API Configuration
# Use /api for production (Vercel rewrites to backend — preferred, same-origin)
# For direct backend access use the full URL INCLUDING /api, e.g.:
#   https://dashboard-backend-hazel.vercel.app/api
# Do NOT omit /api from absolute backend URLs.
VITE_API_URL=/api

# Supabase Configuration
# Get these from your Supabase project settings
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
