# ============================================================================
# KDP Creator Suite Backend - Environment Variables
# ============================================================================
# Copy this file to .env and fill in the actual values for your environment.
# NEVER commit the .env file to version control.
# ============================================================================

# Database Configuration
# Format: postgresql://username:password@host:port/database
# For local development, use: postgresql://postgres:password@localhost:5432/kdp_creator
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.yjzgiunyjmjftpmhezuk.supabase.co:5432/postgres

# Supabase Configuration
# Get these from your Supabase project settings
SUPABASE_URL=https://yjzgiunyjmjftpmhezuk.supabase.co
SUPABASE_ANON_KEY=sb_publishable_uXl7Xz9j3Umko-7sZiZsBA_0dCFiU3K
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT Configuration
# Generate secure random strings for production
# Example: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=kdp-creator-suite-secret-key-2024
JWT_SECRET_KEY=kdp-jwt-secret-key-2024

# JWT Token Expiration (in seconds)
JWT_ACCESS_TOKEN_EXPIRES=86400

# Stripe Configuration (for subscription management)
STRIPE_API_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Application Environment
# Options: development, staging, production
ENVIRONMENT=development

# Debug Mode
# Set to False in production
DEBUG=True

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# Logging Configuration
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Email Configuration (optional, for password resets)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@yourdomain.com

# Feature Flags
ENABLE_2FA=True
ENABLE_BATCH_PROCESSING=True
ENABLE_PDF_PROCESSING=True

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# File Upload Configuration
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,gif

# Vercel Configuration (auto-set in production)
VERCEL_ENV=development
VERCEL_URL=http://localhost:5000
